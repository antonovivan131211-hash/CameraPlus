{
  "schemaVersion": 1,
  "id": "tpcamera",
  "version": "${version}",
  "name": "Camera Plus",
  "description": "Гибко настраиваемая камера для Minecraft. Меняй FOV, смещение, плавность, поведение в 1/3 лице и создавай идеальный вид для игры, строительства и съёмки.",
  "authors": [
    "User"
  ],
  "contact": {
    "sources": "https://github.com/FabricMC/fabric-example-mod"
  },
  "license": "CC0-1.0",
  "icon": "assets/tpcamera/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "ru.tpcamera.ThirdPersonCameraClient"
    ]
  },
  "mixins": [
    {
      "config": "tpcamera.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "fabric-api": "*",
    "minecraft": "~1.20.1",
    "java": ">=17"
  }
}
